{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm --prefix ./apps/control-plane install --no-audit --no-fund",
    "watchPatterns": [
      "/apps/control-plane/**"
    ]
  },
  "deploy": {
    "startCommand": "npm --prefix ./apps/control-plane start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 10
  }
}
